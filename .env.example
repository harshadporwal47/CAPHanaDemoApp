# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to '.env' for local development overrides.
# Never commit '.env' or 'default-env.json' to version control!
# ─────────────────────────────────────────────────────────────────────────────

# Set to 'hybrid' to connect to HANA Cloud, 'development' for SQLite in-memory
CDS_ENV=development

# Optional: override log level (error | warn | info | debug | trace)
# CDS_LOG_LEVEL=debug

# SAP BTP Cloud Foundry trial org/space details (used by cf CLI, not by cds)
# CF_API=https://api.cf.us10.hana.ondemand.com
# CF_ORG=<your-trial-org>
# CF_SPACE=dev
